<view class="page">
  <view class="hero">
    <text class="hero-title">车辆查询结果</text>
    <text class="hero-subtitle">查询码：{{token}}</text>
  </view>

  <view wx:if="{{denied}}" class="card">
    <text class="section-title danger">无权限查看</text>
    <text class="muted">当前账号无权查看车主信息。</text>
    <button class="secondary-btn" bindtap="goScan">返回扫码页</button>
  </view>

  <view wx:elif="{{notFound}}" class="card">
    <text class="section-title danger">未找到车辆</text>
    <text class="muted">二维码无效、车辆已注销，或编号输入错误。</text>
    <button class="secondary-btn" bindtap="goScan">重新扫码</button>
  </view>

  <block wx:else>
    <view class="list-card">
      <text class="section-title">车主信息</text>
      <view class="kv"><text class="kv-label">车主类型</text><text class="kv-value">{{vehicle.ownerTypeText}}</text></view>
      <view class="kv"><text class="kv-label">姓名</text><text class="kv-value">{{vehicle.name}}</text></view>
      <view class="kv"><text class="kv-label">{{vehicle.ownerNoLabel}}</text><text class="kv-value">{{vehicle.ownerNo}}</text></view>
      <view class="kv"><text class="kv-label">{{vehicle.orgLabel}}</text><text class="kv-value">{{vehicle.org || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">{{vehicle.classOrTitleLabel}}</text><text class="kv-value">{{vehicle.classOrTitle || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">手机号</text><text class="kv-value">{{phoneText}}</text></view>
      <button wx:if="{{!showFullPhone}}" class="secondary-btn" bindtap="showPhone">查看完整手机号并记录日志</button>
      <button class="primary-btn" bindtap="makeCall">一键拨打电话</button>
    </view>

    <view class="list-card">
      <text class="section-title">车辆信息</text>
      <view class="kv"><text class="kv-label">车辆类型</text><text class="kv-value">{{vehicle.vehicleType}}</text></view>
      <view class="kv"><text class="kv-label">品牌</text><text class="kv-value">{{vehicle.brand}}</text></view>
      <view class="kv"><text class="kv-label">颜色</text><text class="kv-value">{{vehicle.color}}</text></view>
      <view class="kv"><text class="kv-label">编号</text><text class="kv-value">{{vehicle.plateNo || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">校区/区域</text><text class="kv-value">{{vehicle.campusArea || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">状态</text><text class="kv-value {{vehicle.status === 'revoked' ? 'danger' : 'success'}}">{{vehicle.statusText}} / {{vehicle.reviewStatusText}}</text></view>
      <image wx:if="{{vehicle.photoFilePath}}" class="preview-img" src="{{vehicle.photoFilePath}}" mode="aspectFill" />
      <text wx:else class="muted">暂无车辆照片。</text>
    </view>

    <button class="danger-btn" bindtap="goViolation">登记违停记录</button>

    <view class="list-card">
      <text class="section-title">该车违停记录</text>
      <view wx:if="{{violations.length === 0}}" class="empty">暂无违停记录</view>
      <view wx:for="{{violations}}" wx:key="id" class="field">
        <view class="kv"><text class="kv-label">时间</text><text class="kv-value">{{item.createdAt}}</text></view>
        <view class="kv"><text class="kv-label">地点</text><text class="kv-value">{{item.location}}</text></view>
        <view class="kv"><text class="kv-label">备注</text><text class="kv-value">{{item.remark}}</text></view>
      </view>
    </view>
  </block>
</view>
