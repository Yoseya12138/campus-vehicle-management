<view class="page">
  <view class="hero">
    <text class="hero-title">车辆登记</text>
    <text class="hero-subtitle">登记车主信息、车辆信息并生成车辆二维码</text>
  </view>

  <view class="notice">
    <text>请如实填写车主和车辆信息。提交后将生成待审核车辆二维码，正式接入后由管理员在后台审核通过后生效。</text>
  </view>

  <form bindsubmit="onSubmit">
    <text class="section-title">车主类型</text>
    <view class="form-card">
      <view class="field">
        <text class="label">车主类型 *</text>
        <picker mode="selector" range="{{ownerTypeOptions}}" value="{{ownerTypeIndex}}" bindchange="changeOwnerType">
          <view class="picker-box">{{ownerTypeOptions[ownerTypeIndex]}}</view>
        </picker>
      </view>
      <button class="secondary-btn" type="default" bindtap="clearForm">清空表单</button>
    </view>

    <text class="section-title">{{ownerType === 'teacher' ? '教职工信息' : '学生信息'}}</text>
    <view class="form-card">
      <view class="field">
        <text class="label">姓名 *</text>
        <input name="name" value="{{form.name}}" placeholder="请输入姓名" />
      </view>

      <block wx:if="{{ownerType === 'teacher'}}">
        <view class="field">
          <text class="label">工号 *</text>
          <input name="employeeNo" value="{{form.employeeNo}}" placeholder="请输入工号" />
        </view>
        <view class="field">
          <text class="label">部门/学院</text>
          <input name="department" value="{{form.department}}" placeholder="请输入部门或学院" />
        </view>
        <view class="field">
          <text class="label">职务/身份</text>
          <input name="title" value="{{form.title}}" placeholder="请输入职务或身份" />
        </view>
      </block>

      <block wx:else>
        <view class="field">
          <text class="label">学号 *</text>
          <input name="studentNo" value="{{form.studentNo}}" placeholder="请输入学号" />
        </view>
        <view class="field">
          <text class="label">学院</text>
          <input name="college" value="{{form.college}}" placeholder="请输入学院" />
        </view>
        <view class="field">
          <text class="label">班级</text>
          <input name="className" value="{{form.className}}" placeholder="请输入班级" />
        </view>
      </block>

      <view class="field">
        <text class="label">手机号 *</text>
        <input name="phone" value="{{form.phone}}" type="number" maxlength="11" placeholder="请输入 11 位手机号" />
        <text class="muted">仅授权管理人员可查看完整手机号，普通扫码结果默认脱敏。</text>
      </view>
    </view>

    <text class="section-title">车辆信息</text>
    <view class="form-card">
      <view class="field">
        <text class="label">车辆类型</text>
        <input name="vehicleType" value="{{form.vehicleType || '电动车'}}" placeholder="请输入车辆类型" />
      </view>
      <view class="field">
        <text class="label">品牌 *</text>
        <input name="brand" value="{{form.brand}}" placeholder="请输入车辆品牌" />
      </view>
      <view class="field">
        <text class="label">颜色 *</text>
        <input name="color" value="{{form.color}}" placeholder="请输入车辆颜色" />
      </view>
      <view class="field">
        <text class="label">校内编号/车牌号</text>
        <input name="plateNo" value="{{form.plateNo}}" placeholder="请输入校内编号或车牌号" />
      </view>
      <view class="field">
        <text class="label">校区/停放区域</text>
        <input name="campusArea" value="{{form.campusArea}}" placeholder="请输入校区或停放区域" />
      </view>
      <view class="field">
        <text class="label">车辆照片</text>
        <button class="secondary-btn" type="default" bindtap="chooseImage">选择/拍摄车辆照片</button>
        <image wx:if="{{photoFilePath}}" class="preview-img" src="{{photoFilePath}}" mode="aspectFill" />
        <text wx:else class="muted">未上传车辆照片</text>
      </view>
    </view>

    <view class="form-card consent-card">
      <checkbox-group name="agree">
        <label class="consent-line">
          <checkbox value="yes" color="#1E5AA8" />
          <text>本人确认以上信息真实有效，并同意学校用于车辆登记、扫码核验、违停通知和安全管理。</text>
        </label>
      </checkbox-group>
    </view>

    <button class="primary-btn" formType="submit">提交登记</button>
  </form>

  <view class="list-card">
    <text class="section-title">最近登记</text>
    <view wx:for="{{recentVehicles}}" wx:key="id" class="field">
      <view class="kv"><text class="kv-label">车主</text><text class="kv-value">{{item.ownerTypeText}}：{{item.name}}</text></view>
      <view class="kv"><text class="kv-label">{{item.ownerNoLabel}}</text><text class="kv-value">{{item.ownerNo}}</text></view>
      <view class="kv"><text class="kv-label">车辆</text><text class="kv-value">{{item.color}} {{item.brand}} / {{item.plateNo}}</text></view>
      <view class="kv"><text class="kv-label">编号</text><text class="kv-value">{{item.token}}</text></view>
      <view class="kv"><text class="kv-label">审核状态</text><text class="kv-value">{{item.reviewStatusText}} / {{item.statusText}}</text></view>
    </view>
  </view>
</view>
