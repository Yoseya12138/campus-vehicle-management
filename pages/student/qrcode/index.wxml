<view class="page">
  <view class="hero">
    <text class="hero-title">车辆二维码</text>
    <text class="hero-subtitle">车辆身份识别与信息绑定</text>
  </view>

  <block wx:if="{{hasVehicle}}">
    <view class="qr-box">
      <canvas canvas-id="qrCanvas" class="qr-canvas"></canvas>
      <view class="token">{{qrText}}</view>
      <text class="muted">请将二维码贴于车辆明显位置；待审核车辆请等待管理员审核。</text>
    </view>

    <view class="list-card">
      <text class="section-title">绑定信息</text>
      <view class="kv"><text class="kv-label">车主类型</text><text class="kv-value">{{vehicle.ownerTypeText}}</text></view>
      <view class="kv"><text class="kv-label">姓名</text><text class="kv-value">{{vehicle.name}}</text></view>
      <view class="kv"><text class="kv-label">{{vehicle.ownerNoLabel}}</text><text class="kv-value">{{vehicle.ownerNo}}</text></view>
      <view class="kv"><text class="kv-label">{{vehicle.orgLabel}}</text><text class="kv-value">{{vehicle.org || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">{{vehicle.classOrTitleLabel}}</text><text class="kv-value">{{vehicle.classOrTitle || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">手机号</text><text class="kv-value">{{vehicle.phoneMasked}}</text></view>
      <view class="kv"><text class="kv-label">车辆</text><text class="kv-value">{{vehicle.color}} {{vehicle.brand}}</text></view>
      <view class="kv"><text class="kv-label">校内编号</text><text class="kv-value">{{vehicle.plateNo || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">校区/区域</text><text class="kv-value">{{vehicle.campusArea || '未填写'}}</text></view>
      <view class="kv"><text class="kv-label">二维码编号</text><text class="kv-value">{{vehicle.token}}</text></view>
      <view class="kv"><text class="kv-label">审核状态</text><text class="kv-value">{{vehicle.reviewStatusText}} / {{vehicle.statusText}}</text></view>
    </view>

    <button class="primary-btn" bindtap="copyToken">复制二维码内容</button>
    <button class="secondary-btn" bindtap="goOfficerDetail">查询绑定信息</button>
    <button class="secondary-btn" bindtap="saveQr">保存二维码图片</button>
    <button class="secondary-btn" bindtap="goForm">继续登记</button>
  </block>

  <view wx:else class="empty">
    <text>暂无车辆登记信息</text>
    <button class="primary-btn" bindtap="goForm">去登记</button>
  </view>
</view>
